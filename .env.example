# Optional: override default data directory (~/.talentclaw)
# TALENTCLAW_DIR=

# Coffee Shop API key (set via config.yaml or env)
# COFFEESHOP_API_KEY=

# OpenClaw gateway connection (auto-detected from ~/.openclaw/openclaw.json if not set)
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=
