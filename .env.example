# Anthropic API key (required for agent chat)
# ANTHROPIC_API_KEY=

# Optional: override default data directory (~/.talentclaw)
# TALENTCLAW_DIR=

# Optional: override Claude model (default: claude-sonnet-4-20250514)
# TALENTCLAW_MODEL=

# Coffee Shop API key (set via config.yaml or env)
# COFFEESHOP_API_KEY=
